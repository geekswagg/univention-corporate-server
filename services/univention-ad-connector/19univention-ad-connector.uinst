## joinscript api: bindpwdfile

VERSION=1

. /usr/share/univention-join/joinscripthelper.lib
joinscript_init

SERVICE="AD Connector"

eval "$(ucr shell)"

. /usr/share/univention-lib/ldap.sh
ucs_removeServiceFromLocalhost "$SERVICE" "$@" || die

systemctl restart univention-directory-listener

if [ "$connector_ad_listener_dir" = "/var/lib/univention-connector/ad" ]; then
	find /var/lib/univention-connector/ad /var/lib/univention-connector/ad/tmp/ \
				-type f -exec rm -f '{}' \;
fi

joinscript_remove_script_from_status_file univention-ad-connector

exit 0
