#DEBHELPER#

if [ "$1" = "remove" ]; then
	systemctl try-restart univention-directory-listener

	handler_file=/var/lib/univention-directory-listener/handlers/ad-connector
	test -e "$handler_file" && rm -f "$handler_file"

	db=/etc/univention/connector/internal.sqlite
	test -e "$db" && mv "$db" "${db}_backup_$(date +%Y%m%d%H%M%S)"
fi

exit 0
