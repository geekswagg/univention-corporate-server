## joinscript api: bindpwdfile

VERSION=3

. /usr/share/univention-join/joinscripthelper.lib

joinscript_init

eval "$(univention-config-registry shell)"

/usr/share/univention-directory-manager-tools/univention-dnsedit "$@" "$domainname" remove srv pkgdb tcp 0 0 5432 "$hostname.$domainname." || die

. /usr/share/univention-lib/ldap.sh
ucs_removeServiceFromLocalhost "Software Monitor" "$@" || die

joinscript_remove_script_from_status_file univention-pkgdb

exit 0
