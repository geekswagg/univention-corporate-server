export PYBUILD_NAME=univention-radius
export PYBUILD_AFTER_INSTALL=$(RM) '{destdir}/{install_dir}/univention/__init__.py'

override_dh_fixperms:
	dh_fixperms
	chmod u+s debian/univention-radius/usr/bin/univention-radius-ntlm-auth-suidwrapper

override_dh_auto_clean:
	$(MAKE) clean
	dh_auto_clean

override_dh_auto_build:
	$(MAKE) build
	dh_auto_build

%:
	dh $@ --with python3,ucr --buildsystem=pybuild
