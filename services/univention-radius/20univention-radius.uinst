#!/bin/bash
#
# Univention RADIUS
#  join script (network access schema and extended attribute)
#
# Like what you see? Join us!
# https://www.univention.com/about-us/careers/vacancies/
#
# SPDX-FileCopyrightText: 2014-2025 Univention GmbH
# SPDX-License-Identifier: AGPL-3.0-only

## joinscript api: bindpwdfile

# shellcheck disable=SC2034
VERSION=1
# shellcheck source=/dev/null
. /usr/share/univention-join/joinscripthelper.lib
joinscript_init

# shellcheck source=/dev/null
. /usr/share/univention-lib/all.sh
ucs_removeServiceFromLocalhost 'RADIUS' "$@" || die
if ucs_isServiceUnused 'RADIUS' "$@"
then
	ldap_base="$(ucr get ldap/base)"
	for dn in \
		"cn=networkAccessComputers,cn=custom attributes,cn=univention,$ldap_base" \
		"cn=networkAccessUsers,cn=custom attributes,cn=univention,$ldap_base" \
		"cn=networkAccessGroups,cn=custom attributes,cn=univention,$ldap_base" \
		"cn=univentionRadiusClientSharedSecret,cn=custom attributes,cn=univention,$ldap_base" \
		"cn=univentionRadiusClientType,cn=custom attributes,cn=univention,$ldap_base" \
		"cn=univentionRadiusClientVirtualServer,cn=custom attributes,cn=univention,$ldap_base" \
		"cn=univentionVLanIDGroups,cn=custom attributes,cn=univention,$ldap_base" \
		; do
			udm settings/extended_attribute remove "$@" --dn "$dn"
	done
fi

joinscript_remove_script_from_status_file univention-radius

exit 0
