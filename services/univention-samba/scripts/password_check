import sys

from univention.password import Check, CheckFailed


username = sys.argv[1] if len(sys.argv) > 1 else None

password = sys.stdin.readline()
password = password.strip('\n')

pwdCheck = Check(None, username)

try:
    pwdCheck.check(password)
    sys.exit(0)
except CheckFailed:
    sys.exit(1)
