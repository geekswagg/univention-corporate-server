# msPrint-ConnectionPolicy
objectclass ( 1.3.6.1.4.1.10176.4107.2.1 NAME 'msPrintConnectionPolicy'
	DESC 'msPrintConnectionPolicy'
	SUP top STRUCTURAL
	Must ( cn )
	MAY (
		description $
		displayName $
		msPrintAttributes $
		msPrinterName $
		msPrintServerName $
		msPrintUNCName
		)
	)
