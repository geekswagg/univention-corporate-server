. /usr/lib/univention-server/lib/server_password_change/debug.sh

if [ "$1" = "postchange" ] ; then
	dest="/etc/squid.secret"
	cp /etc/machine.secret "$dest"
	chown proxy:root "$dest"
	chmod 600  "$dest"
fi
