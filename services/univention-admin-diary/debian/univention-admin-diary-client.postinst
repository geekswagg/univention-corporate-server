#DEBHELPER#

case "$1" in
configure)
	systemctl try-restart univention-directory-listener
	;;
abort-upgrade|abort-remove|abort-deconfigure)
	;;
*)
	echo "postinst called with unknown argument \`$1'" >&2
	exit 1
	;;
esac

exit 0
