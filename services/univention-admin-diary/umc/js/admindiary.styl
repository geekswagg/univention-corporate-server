.admindiaryOverview
	.dgrid-row
		cursor: pointer

	td.dgrid-cell.field-comments
		font-size: x-large

	.admindiaryOverview__queryLimitWarning
		padding-bottom: 1em

		code
			font-size: 1em

article.admindiary
	margin-bottom: 8ex

	blockquote
		margin-bottom: 0
		padding: 1rem 0 1rem 3rem
		background-position: left
		background-repeat: no-repeat
		border: none
		border-top: 2px solid var(--bgc-content-body)
		border-bottom: 2px solid var(--bgc-content-body)
	blockquote.software
		background-image: url("admindiary/icons/software.svg")
	blockquote.devices
		background-image: url("admindiary/icons/devices.svg")
	blockquote.users
		background-image: url("admindiary/icons/users.svg")
	blockquote.domain
		background-image: url("admindiary/icons/domain.svg")
	blockquote.default
		background-image: url("admindiary/icons/default.svg")
	blockquote.comment
		background-image: url("admindiary/icons/comment.svg")
	address
		text-align: right
		font-size: var(--font-size-5)
		line-height: var(--lineheight-normal)
		margin: var(--layout-spacing-unit) 0 0 0
		float: right
	span
		margin: var(--layout-spacing-unit) 0 0 0

.umcTopContainer--layout-admindiary-overviewpage
	.umcPage .umcPageFooter
		flex: 1 0 auto
		display: flex
		align-items: flex-end
		margin: 0 0 16px 0

		> div:first-child
			flex: 1 0 auto

	.umcGrid--filtering .dgrid
		max-height: 56px !important // kinda hacky

.umc .umcGrid .dgrid-cell:first-child
	padding-left: 1rem
.umc .umcGrid .dgrid-cell:last-child
	padding-right: 1eem
