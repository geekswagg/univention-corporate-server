if [ "$1" = "configure" ] && dpkg --compare-versions "$2" lt-nl 14.0.0-1
then
	ucr set postgres15/password-encryption=md5 postgres15/pg_hba/password-encryption=md5
fi

#DEBHELPER#

exit 0
