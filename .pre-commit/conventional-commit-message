type_mapping = {
    'ucs-test': 'test',
    'ucs-test-tools': 'test',
    'ucslint': 'ci',
}


def main():
    parser = argparse.ArgumentParser(description=__doc__)
    subparsers = parser.add_subparsers(dest='action', title='actions', description='All available actions')
    changelog = subparsers.add_parser('debian-changelog', help=parse_changelog.__doc__)
    changelog.add_argument("changelog", help="Path to debian/changelog")
    changelog.set_defaults(func=parse_changelog)
    advisory = subparsers.add_parser('errata-advisory', help=parse_advisory.__doc__)
    advisory.add_argument("advisory", help="Path to doc/errata/{staging,published}/*.yaml")
    advisory.set_defaults(func=parse_advisory)
    args = parser.parse_args()
    args.func(args)


def parse_changelog(args):
    """Take message from parsing debian/changelog"""
    # dpkg-parsechangelog -c1 -l"$f" --format dpkg | sed -e '/^Changes:/,+2 d;/^ /!d'
    changelog = subprocess.check_output([
        'dpkg-parsechangelog', '-c1', '-l', args.changelog, '--format', 'dpkg', '-SChanges',
    ]).decode('UTF-8', 'replace')
    changelog, _, all_changes = changelog.partition('\n.\n')
    for changes in reversed(all_changes.split('\n.\n')):
        _author, changes = changes.split('* ', 1)
        changes = changes.strip().replace('\n', '')
        while '  ' in changes:
            changes = changes.replace('  ', ' ')
        package = changelog.strip().split(None, 1)[0]

        issue, changes = changes.split(': ', 1)
        scope = mapping.get(package, package)
        type_ = type_mapping.get(package, 'feat')
        print(f'{type_}({scope}): {changes}\n\n{issue}')


def parse_advisory(args):
    """Take message from parsing errata advisory"""
    with open(args.advisory) as fd:
        erratum = yaml.safe_load(fd)
    bug = erratum['bug'][-1]
    src = erratum['src']
    src = mapping.get(src, src)

    print(f'chore({src}): update advisory\n\nBug #{bug}')


main()
