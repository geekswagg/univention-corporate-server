override_dh_fixperms:
	dh_fixperms
	chmod 2750 debian/univention-mail-dovecot/var/lib/dovecot
	chmod 2755 debian/univention-mail-dovecot/var/lib/dovecot/sieve
	chmod 0700 debian/univention-mail-dovecot/var/spool/univention-mail-dovecot
	chmod 2750 debian/univention-mail-dovecot/var/spool/dovecot/*

%:
	dh $@ --with python3,ucr
