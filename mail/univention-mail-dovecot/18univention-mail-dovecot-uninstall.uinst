## joinscript api: bindpwdfile

VERSION=1

. /usr/share/univention-join/joinscripthelper.lib

joinscript_init

. /usr/share/univention-lib/ldap.sh
ucs_removeServiceFromLocalhost "IMAP" "$@" || die

if ucs_isServiceUnused "IMAP" "$@"
then
	eval "$(ucr shell)"
	udm settings/extended_attribute remove "$@" \
		--dn "cn=UniventionDovecotUserQuota,cn=custom attributes,cn=univention,$ldap_base"
fi

joinscript_remove_script_from_status_file univention-mail-dovecot

exit 0
