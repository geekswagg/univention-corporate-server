## joinscript api: bindpwdfile

VERSION=1

. /usr/share/univention-join/joinscripthelper.lib
joinscript_init


eval "$(ucr shell)"

if [ ! "$nagios_client_autoregister" = "no" ] ; then
	for device in sda sdb sdc sdd; do
		dev=$(echo $device | tr a-z A-Z)
		univention-directory-manager nagios/service modify "$@" --ignore_exists \
				--dn "cn=UNIVENTION_SMART_${dev},cn=nagios,$ldap_base" \
				--remove assignedHosts="$ldap_hostdn"
	done
fi

joinscript_remove_script_from_status_file univention-nagios-smart

exit 0

