#DEBHELPER#

eval "$(univention-config-registry shell server/role)"

if [ "$server_role" = "domaincontroller_master" -o "$server_role" = "domaincontroller_backup" ]; then
	# run join script
	/usr/lib/univention-install/35univention-nagios-cups.inst
fi

exit 0
