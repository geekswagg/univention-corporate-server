#DEBHELPER#

if [ "$1" = "configure" ]; then
	uinst=/usr/lib/univention-install/69univention-nagios-s4-connector.uinst
	[ -e "$uinst" ] && rm "$uinst"
fi

. /usr/share/univention-lib/base.sh
call_joinscript 31univention-nagios-s4-connector.inst

exit 0
