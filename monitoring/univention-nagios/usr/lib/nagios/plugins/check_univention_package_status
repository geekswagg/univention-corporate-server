VERSION="1.00"
PROGNAME=`/usr/bin/basename $0`
VERBOSE=0

STATE_OK=0
STATE_WARNING=1
STATE_CRITICAL=2
STATE_UNKNOWN=3

get_state_string() {
	if [ "$1" = "$STATE_OK" ] ; then
		STATE_STRING="OK"
	elif [ "$1" = "$STATE_WARNING" ] ; then
		STATE_STRING="WARNING"
	elif [ "$1" = "$STATE_CRITICAL" ] ; then
		STATE_STRING="CRITICAL"
	else
		STATE_STRING="UNKNOWN"
    fi
}

print_revision() {
    echo "$PROGNAME: version $VERSION"
}

print_usage() {
    echo "Usage: $PROGNAME --help"
    echo "Usage: $PROGNAME --version"
}

print_help() {
    print_revision
    echo ""
    print_usage
}

exit_with_msg() {
	get_state_string $1
	echo "${STATE_STRING}: $2"
	exit $1
}


while test -n "$1"; do
    case "$1" in
        --help)
            print_help
            exit $STATE_OK
            ;;
        -h)
            print_help
            exit $STATE_OK
            ;;
        --version)
            print_revision
            exit $STATE_OK
            ;;
        -V)
            print_revision
            exit $STATE_OK
            ;;
    esac
    shift
done


# Find half-configured and
#       (exit 1 in postinst)
#  half-installed packages
#       (exit 1 in postrm)
msg="$(dpkg-query -f '${status} ${package}\n' -W | awk '$3 ~ "half" {printf $4 " "}')"


if [ -n "$msg" ] ; then
	exit_with_msg $STATE_CRITICAL "Package status broken for $msg"
fi


exit_with_msg $STATE_OK "Package status OK"
