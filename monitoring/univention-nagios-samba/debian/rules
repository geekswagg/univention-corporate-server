override_dh_auto_build:
	make check_univention_samba_drs_failures_suidwrapper
	dh_auto_build

override_dh_fixperms:
	dh_fixperms
	chmod 4775 debian/univention-nagios-samba/usr/lib/nagios/plugins/check_univention_samba_drs_failures_suidwrapper

%:
	dh $@ --with ucr
