#DEBHELPER#

eval "$(ucr shell server/role ldap/base)"

if [ "$server_role" = "domaincontroller_master" ] && dpkg --compare-versions "$2" lt-nl 1.0.0-2; then
	udm monitoring/alert modify --ignore_not_exists \
		--dn "cn=UNIVENTION_CUPS_MISSING,cn=monitoring,$ldap_base" \
		--set query="absent(univention_cups_running) == 1 or absent(univention_cups_reachable) == 1"
fi

exit 0