#!/bin/bash
#
# Univention Monitoring Client
#  join script
#
# Like what you see? Join us!
# https://www.univention.com/about-us/careers/vacancies/
#
# SPDX-FileCopyrightText: 2022-2025 Univention GmbH
# SPDX-License-Identifier: AGPL-3.0-only

## joinscript api: bindpwdfile

VERSION=2

. /usr/share/univention-join/joinscripthelper.lib
. /usr/share/univention-lib/all.sh
joinscript_init

eval "$(univention-config-registry shell)"

univention-directory-manager monitoring/alert create "$@" --ignore_exists \
	--position "cn=monitoring,$ldap_base" \
	--set name="UNIVENTION_RAID_WARNING" \
	--set alertGroup="UNIVENTION_RAID" \
	--set description="RAID status in /proc/mdstat" \
	--set summary="check RAID status in /proc/mdstat" \
	--append labels='"severity" "warning"' \
	--set query='{__name__=~"univention_i2o_raid_.+",%instance%} >= 11 and {__name__=~"univention_i2o_raid_.+",%instance%} < 20' || die "UNIVENTION_RAID_WARNING"

univention-directory-manager monitoring/alert create "$@" --ignore_exists \
	--position "cn=monitoring,$ldap_base" \
	--set name="UNIVENTION_RAID" \
	--set description="RAID status in /proc/mdstat" \
	--set summary="check RAID status in /proc/mdstat" \
	--append labels='"severity" "critical"' \
	--set query='{__name__=~"univention_i2o_raid_.+",%instance%} >= 20' || die "UNIVENTION_RAID_WARNING"

univention-directory-manager monitoring/alert create "$@" --ignore_exists \
	--position "cn=monitoring,$ldap_base" \
	--set name="UNIVENTION_RAID_MISSING" \
	--set description="metrics for RAID status are missing" \
	--set summary="check metrics for RAID status exists" \
	--append labels='"severity" "critical"' \
	--set query='absent(univention_i2o_raid_physical{%instance%}) == 1 or absent(univention_i2o_raid_logical{%instance%}) == 1 or absent(univention_i2o_raid_controller{%instance%}) == 1 or absent(univention_i2o_raid_raid{%instance%}) == 1' || die "UNIVENTION_RAID_MISSING"

if [ $JS_LAST_EXECUTED_VERSION -eq 1 ]; then
	univention-directory-manager monitoring/alert modify "$@" \
		--dn "cn=UNIVENTION_RAID_WARNING,cn=monitoring,$ldap_base" \
		--set description="RAID status in /proc/mdstat" \
		--set summary="check RAID status in /proc/mdstat" \
		--set query='{__name__=~"univention_i2o_raid_.+",%instance%} >= 11 and {__name__=~"univention_i2o_raid_.+",%instance%} < 20'

	univention-directory-manager monitoring/alert modify "$@" \
		--dn "cn=UNIVENTION_RAID,cn=monitoring,$ldap_base" \
		--set description="RAID status in /proc/mdstat" \
		--set summary="check RAID status in /proc/mdstat" \
		--set query='{__name__=~"univention_i2o_raid_.+",%instance%} >= 20'

	univention-directory-manager monitoring/alert modify "$@" \
		--dn "cn=UNIVENTION_RAID_MISSING,cn=monitoring,$ldap_base" \
		--set description="metrics for RAID status are missing" \
		--set summary="check metrics for RAID status exists" \
		--set query='absent(univention_i2o_raid_physical{%instance%}) == 1 or absent(univention_i2o_raid_logical{%instance%}) == 1 or absent(univention_i2o_raid_controller{%instance%}) == 1 or absent(univention_i2o_raid_raid{%instance%}) == 1'
fi

CHECKS=(
	"UNIVENTION_RAID"
	"UNIVENTION_RAID_WARNING"
	"UNIVENTION_RAID_MISSING"
)

if [ $JS_LAST_EXECUTED_VERSION -le 0 ] && is_ucr_true monitoring/client/nagios-automigration; then
	/usr/share/univention-monitoring-client/migrate-nagios-services-to-alerts "$@" || die "Could not migrate nagios service to alerts"
elif ! is_ucr_false monitoring/client/autoregister; then
	# univention-directory-manager "computers/${server_role}" modify "$@" --dn "$ldap_hostdn" --append-option="monitoring" || die
	for name in "${CHECKS[@]}"; do
		univention-directory-manager monitoring/alert modify "$@" \
			--dn "cn=$name,cn=monitoring,$ldap_base" \
			--append assignedHosts="${ldap_hostdn}" || die
	done
fi
joinscript_save_current_version

exit 0
