#! /bin/sh
#
# Univention LDAP Admins User
#  join script
#
# Like what you see? Join us!
# https://www.univention.com/about-us/careers/vacancies/
#
# SPDX-FileCopyrightText: 2010-2025 Univention GmbH
# SPDX-License-Identifier: AGPL-3.0-only

## joinscript api: bindpwdfile

# shellcheck disable=SC2034
VERSION=2
# shellcheck source=/dev/null
. /usr/share/univention-join/joinscripthelper.lib
# shellcheck source=/dev/null
. /usr/share/univention-lib/umc.sh

joinscript_init

eval "$(univention-config-registry shell)"

# create user group with permission to reset user passwords
univention-directory-manager groups/group create "$@" --ignore_exists \
	--position "cn=groups,${ldap_base:?}" \
	--set name="User Password Admins" \
	--set description="See user attributes and reset user passwords" || die
univention-config-registry set \
	ldap/acl/user/passwordreset/accesslist/groups/dn"?cn=User Password Admins,cn=groups,${ldap_base:?}" \
	ldap/acl/user/passwordreset/protected/gid?'Domain Admins' \
	ldap/acl/user/passwordreset/attributes?"krb5Key,userPassword,sambaPwdCanChange,sambaPwdMustChange,sambaLMPassword,sambaNTPassword,sambaPwdLastSet,pwhistory,sambaPasswordHistory,krb5KDCFlags,krb5KeyVersionNumber,krb5PasswordEnd,shadowMax,shadowLastChange"

umc_init
udm policies/umc create "$@" --ignore_exists --set name=default-user-password-admins \
	--position "cn=UMC,cn=policies,$ldap_base"
# Add udm-users operation to policy; only users module is visible
umc_policy_append "default-user-password-admins" "udm-users"

# Set default policy for User Password Admins group
udm groups/group modify "$@" --dn "cn=User Password Admins,cn=groups,$ldap_base" \
	--policy-reference "cn=default-user-password-admins,cn=UMC,cn=policies,$ldap_base"

systemctl try-restart slapd.service

joinscript_save_current_version

exit 0
