## joinscript api: bindpwdfile

VERSION=3

. /usr/share/univention-join/joinscripthelper.lib
. /usr/share/univention-lib/umc.sh

joinscript_init
umc_init

if joinscript_check_version_in_range_executed 1 2; then
	udm settings/umc_operationset remove "$@" --dn "cn=reboot-all,cn=operations,cn=UMC,cn=univention,$ldap_base" || exit 1
fi

umc_operation_create "reboot-all" "Reboot" "" "reboot/*" "lib/server/reboot" "lib/server/shutdown"
umc_policy_append "default-umc-all" "reboot-all"

joinscript_save_current_version

exit 0
