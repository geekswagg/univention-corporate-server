#!/bin/sh
#
# Restart the Directory Notifier after an interface was stopped.
#  See https://forge.univention.org/bugzilla/show_bug.cgi?id=30408
#
# Like what you see? Join us!
# https://www.univention.com/about-us/careers/vacancies/
