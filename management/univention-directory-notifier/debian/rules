override_dh_auto_clean:
	$(MAKE) -C src clean
	dh_auto_clean

override_dh_fixperms:
	chmod 755 debian/univention-directory-notifier/etc/network/if-post-down.d/univention-directory-notifier
	dh_fixperms

override_dh_auto_build:
	$(MAKE) -C src
	dh_auto_build

%:
	dh $@ --with ucr
