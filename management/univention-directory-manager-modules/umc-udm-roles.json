{
  "domainadmin": [
    {
      "condition": {
        "position": "*"
      },
      "permissions": {
        "*": {
          "attributes": {
            "*": "write"
          },
          "create": true,
          "delete": true
        }
      }
    }
  ],
  "linux-client-manager": [
    {
      "condition": {
        "position": "",
        "scope": "base"
      },
      "permissions": {
        "container/dc": {
          "attributes": {
            "*": {
              "access": "read"
            }
          },
          "create": false,
          "delete": false
        }
      }
    },
    {
      "condition": {
        "position": "$CONTEXT",
        "scope": "subtree"
      },
      "permissions": {
        "computers/linux": {
          "attributes": {
            "*": {
              "access": "write"
            }
          },
          "create": true,
          "delete": true
        },
        "container/cn": {
          "attributes": {
            "*": {
              "access": "read"
            }
          },
          "create": false,
          "delete": false
        },
        "groups/group": {
          "attributes": {
            "*": {
              "access": "read"
            }
          }
        }
      }
    },
    {
      "condition": {
        "position": "cn=groups",
        "scope": "one"
      },
      "permissions": {
        "groups/group": {
          "attributes": {
            "*": {
              "access": "read"
            },
            "hosts": {
              "access": "write"
            }
          }
        }
      }
    },
    {
      "condition": {
        "position": "*",
        "scope": "one"
      },
      "permissions": {
        "settings/cn": {
          "attributes": {
            "*": {
              "access": "read"
            }
          }
        },
        "settings/default": {
          "attributes": {
            "*": {
              "access": "read"
            }
          }
        }
      }
    }
  ],
  "ouadmin": [
    {
      "condition": {
        "position": "$CONTEXT",
        "scope": "subtree"
      },
      "permissions": {
        "*": {
          "attributes": {
            "*": "write",
            "guardianMemberRoles": "read",
            "guardianRoles": "read"
          },
          "create": true,
          "delete": true
        }
      }
    },
    {
      "condition": {
        "position": "cn=groups",
        "scope": "base"
      },
      "permissions": {
        "groups/group": {
          "attributes": {
            "*": "read"
          }
        }
      }
    },
    {
      "condition": {
        "position": "cn=domain,cn=mail",
        "scope": "base"
      },
      "permissions": {
        "mail/domain": {
          "attributes": {
            "*": "read"
          }
        }
      }
    },
    {
      "condition": {
        "position": "*",
        "scope": "base"
      },
      "permissions": {
        "policies/desktop": {
          "attributes": {
            "*": "read"
          }
        },
        "policies/pwhistory": {
          "attributes": {
            "*": "read"
          }
        },
        "policies/umc": {
          "attributes": {
            "*": "read"
          }
        },
        "settings/cn": {
          "attributes": {
            "*": {
              "access": "read"
            }
          }
        },
        "settings/directory": {
          "attributes": {
            "*": {
              "access": "read"
            }
          }
        }
      }
    }
  ]
}
