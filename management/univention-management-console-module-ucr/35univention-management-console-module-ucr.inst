## joinscript api: bindpwdfile

VERSION=2

. /usr/share/univention-join/joinscripthelper.lib
. /usr/share/univention-lib/umc.sh

joinscript_init

umc_init
umc_operation_create "ucr-all" "UCR management" "" "ucr/*"
umc_operation_create "ucr-read" "UCR read-only access" "" "ucr/query"
umc_policy_append "default-umc-all" "ucr-all"

joinscript_save_current_version

exit 0


