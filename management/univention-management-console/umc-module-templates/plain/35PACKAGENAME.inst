## joinscript api: bindpwdfile

VERSION=1

. /usr/share/univention-join/joinscripthelper.lib
. /usr/share/univention-lib/umc.sh

joinscript_init

umc_init
umc_operation_create "MODULEID-all" "MODULENAME" "" "MODULEID/*"
umc_policy_append "default-umc-all" "MODULEID-all"

joinscript_save_current_version

exit 0
