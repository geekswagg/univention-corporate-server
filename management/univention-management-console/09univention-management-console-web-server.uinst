## joinscript api: bindpwdfile

VERSION=1

. /usr/share/univention-join/joinscripthelper.lib
joinscript_init

eval "$(ucr shell)"

. /usr/share/univention-lib/ldap.sh
ucs_removeServiceFromLocalhost 'Univention Management Console' "$@" || die

if [ -n "$umc_saml_sp_server" ]; then
	fqdn="$umc_saml_sp_server"
else
	fqdn="$hostname.$domainname"
fi

udm saml/serviceprovider remove "$@" --dn "SAMLServiceProviderIdentifier=https://$fqdn/univention/saml/metadata,cn=saml-serviceprovider,cn=univention,$ldap_base" || die

rm /usr/share/univention-management-console/saml/idp/*.xml || die
ucr unset umc/saml/idp-server || die

deb-systemd-invoke restart univention-management-console-server
/etc/init.d/slapd crestart

joinscript_remove_script_from_status_file univention-management-console-web-server

exit 0
