. /usr/share/univention-lib/all.sh

univention-config-registry set ldap/policy/cron?"5 * * * *"

#DEBHELPER#

create_logfile /var/log/univention/ldap-policy.log "root:adm" 640

call_joinscript 20univention-directory-policy.inst

exit 0
