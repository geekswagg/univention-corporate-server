# SPDX-FileCopyrightText: 2014-2025 Univention GmbH
# SPDX-License-Identifier: AGPL-3.0-only

## joinscript api: bindpwdfile

# shellcheck disable=SC2034
VERSION=2

# shellcheck source=/dev/null
. /usr/share/univention-join/joinscripthelper.lib
# shellcheck source=/dev/null
. /usr/share/univention-lib/umc.sh

joinscript_init

umc_init
umc_operation_create "diagnostic-all" "diagnostic" "" "diagnostic/*"
umc_policy_append "default-umc-all" "diagnostic-all"

# create default policies if not exists and append operationset to it
for name in 'default-slave-umc' 'default-backup-umc'; do
	udm policies/umc create "$@" --ignore_exists --set "name=$name" --position "cn=UMC,cn=policies,${ldap_base:?}" || die
	umc_policy_append "$name" "diagnostic-all"
done

joinscript_save_current_version

exit 0
