## joinscript api: bindpwdfile

VERSION=1
. /usr/share/univention-join/joinscripthelper.lib
joinscript_init

univention-config-registry set nsswitch/ldap=yes

test -x /etc/init.d/nscd && service nscd restart
ucr commit /etc/sssd/sssd.conf
service sssd restart

eval "$(univention-config-registry shell server/role ldap/master)"

if [ "$server_role" = "memberserver" ]; then
	univention-config-registry set ldap/server/name="$ldap_master"
fi

joinscript_save_current_version
exit 0
