#DEBHELPER#

eval "$(univention-config-registry shell)"

restart_slapd ()
{
	/etc/init.d/slapd stop
	sleep 1
	if [ -n "$(pidof slapd)" ]; then
		killall slapd
		sleep 1
		if [ -n "$(pidof slapd)" ]; then
			killall -9 slapd
			sleep 1
		fi
	fi
	/etc/init.d/slapd start
}

if [ "$1" = "configure" ]; then
	if [ "$server_role" = "domaincontroller_master" ]; then
		if dpkg --compare-versions "$2" lt-nl 18.2.3; then
			restart_slapd
		fi
	fi
fi

exit 0
