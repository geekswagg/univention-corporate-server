objectclass ( 1.3.6.1.4.1.10176.4105.2.2 NAME 'msGPOContainer'
	DESC 'MS GPO Policy Container'
	SUP top STRUCTURAL
	Must ( cn )
	MAY (
		description $
		displayName $
		msGPOFlags $
		msGPOVersionNumber $
		msGPOSystemFlags $
		msGPOFunctionalityVersion $
		msGPOFileSysPath $
		msGPOUserExtensionNames $
		msGPOMachineExtensionNames $
		msGPOWQLFilter $
		msNTSecurityDescriptor
		)
	)
