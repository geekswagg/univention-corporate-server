# SPDX-License-Identifier: AGPL-3.0-only

if [ "$1" = "configure" ] && [ -z "$2" ]
then
	update-inetd --multi --remove time
	invoke-rc.d openbsd-inetd restart
fi

install -o ntpsec -g ntpsec -m 750 -d /var/log/ntpsec

#DEBHELPER#

exit 0
