xargs -d '\n' univention-config-registry set <<__UCR__
samba/share/home?no
samba/share/netlogon?no
server/password/interval?21
server/role=memberserver
server/password/cron?0 1 * * *
__UCR__

#DEBHELPER#

exit 0
