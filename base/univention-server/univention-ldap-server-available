eval "$(/usr/sbin/univention-config-registry shell 'ldap/server/.*')"

# shellcheck disable=SC2154
for h in $ldap_server_name $ldap_server_addition
do
	[ -n "$h" ] &&
		netcat -q0 -w4 "$h" "${ldap_server_port:-7389}" </dev/null >/dev/null 2>&1 &&
		exit 0
done
exit 1
