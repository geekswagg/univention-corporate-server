## joinscript api: bindpwdfile

VERSION=1

. /usr/share/univention-join/joinscripthelper.lib
joinscript_init

eval "$(ucr shell ldap/base)"

udm settings/udm_module modify "$@" --ignore_not_exists \
	--dn "cn=portals/portal,cn=udm_module,cn=univention,$ldap_base" \
	--append messagecatalog="fr $(base64 /usr/lib/univention-portal/udm/fr.mo)" || die

joinscript_save_current_version

exit 0
