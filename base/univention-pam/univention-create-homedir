test -z "$USER" && exit 1
test -z "$HOME" && exit 1

if [ -x "/usr/sbin/univention-mount-homedir" ]; then
	exec /usr/sbin/univention-mount-homedir
elif ! [ -d "$HOME" ]; then
	mkdir $HOME
	chown `getent passwd $USER | awk -F : '{print $3":"$4}'` $HOME
fi
