## joinscript api: bindpwdfile

VERSION=3
. /usr/share/univention-join/joinscripthelper.lib
joinscript_init

eval "$(univention-config-registry shell hostname domainname)"
. /usr/share/univention-lib/all.sh
FQDN="$hostname.$domainname"

if is_ucr_true "local/repository"
then
	REPO="univention-repository.$domainname"
	# Is there already another repository server?
	target="$(LC_ALL=C host -t CNAME "$REPO" | sed -ne 's|.* is an alias for \(.*\)\.$|\1|p')"
	if [ -z "$target" ]; then
		target="$(LC_ALL=C host "$REPO" | sed -ne 's|.* has \(IPv6 \)\?address ||p')"
	fi

	case "$target" in
	"")
		univention-config-registry set repository/mirror/server=https://updates.software-univention.de/
		/usr/share/univention-directory-manager-tools/univention-dnsedit "$@" --stoptls \
			--ignore-exists "$domainname" add cname univention-repository "$FQDN."
		;;
	"$hostname"|"$FQDN")
		# Ensure that CNAME is FQDN.
		/usr/share/univention-directory-manager-tools/univention-dnsedit "$@" --stoptls \
			--overwrite "$domainname" add cname univention-repository "$FQDN."
		;;
	*)
		univention-config-registry set repository/mirror/server="$REPO"
		;;
	esac

	ucs_addServiceToLocalhost "Repository-Server" "$@" || die
fi

univention-config-registry set \
	repository/online/server="http://$FQDN" \
	repository/online/prefix="univention-repository"

joinscript_save_current_version
exit 0
