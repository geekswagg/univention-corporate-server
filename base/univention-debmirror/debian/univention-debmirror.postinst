. /usr/share/univention-lib/all.sh

eval "$(univention-config-registry shell)"

#DEBHELPER#

# activate local repository on installation only
if [ "$1" = "configure" ] && [ -z "$2" ]; then
	univention-config-registry set local/repository?yes
fi

call_joinscript 77univention-debmirror.inst

a2ensite univention-repository
/etc/init.d/apache2 reload || true

exit 0
