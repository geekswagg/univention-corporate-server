%:
	dh $@

override_dh_auto_clean:
	dh_auto_clean
	[ ! -f Makefile ] || $(MAKE) maintainer-clean

override_dh_auto_configure:
	libtoolize
	aclocal
	autoconf
	automake --add-missing
	dh_auto_configure
