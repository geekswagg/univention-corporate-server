univention_app_cmd_exists() {
	[ -x /usr/bin/univention-app ]
	return $?
}

is_app_center_server_reachable() {
	SERVER="$(univention-config-registry get repository/app_center/server)"
	[ -z "$SERVER" ] && return 1
	ping -c 3 "$SERVER" > /dev/null 2>&1
	return $?
}

univention_app_cmd_exists && is_app_center_server_reachable && univention-app update

