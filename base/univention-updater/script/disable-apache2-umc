die () {
	echo "${0##/*}: $*" >&2
	exit 1
}
opt="$(getopt -o 'h' --longoptions 'exclude-apache,help' -- "$@")" ||
	die 'Terminating...'
eval set -- "$opt"
while [ $# -ge 1 ]
do
	case "$1" in
	-h|--help)
		echo "${0##*/} [--help] [--exclude-apache]"
		exit 0
		;;
	--exclude-apache)
		echo "$0: DEPRECATED --exclude-apache"
		shift
		;;
	--)
		shift
		break
		;;
	*)
		die 'Internal error!'
		;;
	esac
done

systemctl mask --runtime univention-management-console-server.service

exit 0
