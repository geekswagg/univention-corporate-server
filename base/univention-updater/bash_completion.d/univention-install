_uniinstall () {
    # shellcheck disable=SC2034
    local cur prev words cword
    _init_completion || return
    mapfile -t COMPREPLY < <(exec apt-cache --no-generate pkgnames -- "$cur" 2>/dev/null)
    return 0
}
complete -F _uniinstall univention-install
