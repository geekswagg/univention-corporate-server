## joinscript api: bindpwdfile

# shellcheck disable=SC2034
VERSION=3

# shellcheck source=/dev/null
. /usr/share/univention-join/joinscripthelper.lib
# shellcheck source=/dev/null
. /usr/share/univention-lib/umc.sh

joinscript_init

umc_init

eval "$(ucr shell ldap/base)"

if [ "$JS_LAST_EXECUTED_VERSION" -le 2 ] && [ "$JS_LAST_EXECUTED_VERSION" -gt 0 ]; then
	# remove previous operation sets as updater-all needs to grant access to lib/server/*
	udm settings/umc_operationset remove "$@" --dn "cn=updater-all,cn=operations,cn=UMC,cn=univention,${ldap_base:?}" || die
fi

umc_operation_create "updater-all" "Online Update" "" "updater/*" "lib/server/*"

umc_policy_append "default-umc-all" "updater-all"

joinscript_save_current_version

exit 0
